# SiliconFlow Test Environment Configuration
LLM_API_BASE=https://api.siliconflow.cn/v1
LLM_API_KEY=your_siliconflow_api_key_here
LLM_MODEL_NAME=Qwen/Qwen3.5-35B-A3B

# BAAI Embedding on SiliconFlow
LLM_EMBEDDING_API_BASE=https://api.siliconflow.cn/v1
LLM_EMBEDDING_MODEL_NAME=Qwen/Qwen3-Embedding-8B

# BAAI Reranker on SiliconFlow
RERANKER_ENDPOINT=https://api.siliconflow.cn/v1/rerank
RERANKER_MODEL_NAME=Qwen/Qwen3-Reranker-8B

# VLM remains on 192.168.8.6 (Local) unless SiliconFlow supports VL internally soon
VLM_API_BASE=https://api.siliconflow.cn/v1
VLM_MODEL_NAME=Qwen/Qwen3-VL-8B-Instruct

# Gateway Auth (仅生产部署需要，本地运行可保持默认值不修改)
GATEWAY_AUTH_TOKEN=your_gateway_auth_token_here
